%% Figure 3: Evidence and claim boundary map
flowchart LR
    subgraph Evidence["Evidence sources"]
        TUT["AGT case study<br/>reported repair facts"]
        TESTS["Regression tests<br/>stdio, HTTP/SSE, pagination,<br/>exit codes, hardening"]
        EVAL["Evil MCP loop<br/>30 synthetic metadata cases"]
        SANDBOX["ProjectOpenHandMonk sandbox checks<br/>EvilBench + DVMCP reports"]
    end

    subgraph Supported["Supported claims"]
        CLI["CLI contract repaired"]
        ENUM["Advertised MCP metadata can be enumerated"]
        FIND["Metadata findings flow into<br/>AGT scanner/report outputs"]
        AUTO["Critical outcomes can drive<br/>CI-relevant exit code 2"]
    end

    subgraph NotSupported["Not claimed by this paper"]
        CERT["Benchmark certification"]
        PREV["Runtime exploit prevention"]
        FULL["Complete OWASP MCP coverage"]
        RATE["False-positive / false-negative rate"]
    end

    TUT --> CLI
    TUT --> ENUM
    TESTS --> ENUM
    TESTS --> FIND
    TESTS --> AUTO
    EVAL --> FIND
    SANDBOX --> FIND

    Evidence -. "does not establish" .-> NotSupported

    classDef evidence fill:#e7f5ff,stroke:#1c7ed6,color:#102a43;
    classDef supported fill:#d3f9d8,stroke:#2b8a3e,color:#123b1e;
    classDef caution fill:#fff3bf,stroke:#f08c00,color:#3b2f00;
    class TUT,TESTS,EVAL,SANDBOX evidence;
    class CLI,ENUM,FIND,AUTO supported;
    class CERT,PREV,FULL,RATE caution;
